# Local development env template. Copy what you need into `.env.local`.
# Real secrets live in Vercel project settings — do not commit them here.

# Sentry observability (Wave 2 / issue #152). Leave unset for local dev to
# get console-only breadcrumbs. Set both to enable Sentry in dev.
# NEXT_PUBLIC_SENTRY_DSN=<set-in-vercel-dashboard>
# SENTRY_DSN=<same-as-above-for-server-runtime>

# Optional Sentry tuning:
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_ENVIRONMENT=development

# Required for source-map upload at build time. Only set in CI / Vercel.
# SENTRY_AUTH_TOKEN=<vercel-secret>
