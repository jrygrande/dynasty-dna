# Local development environment template.
#
# Setup:
#   1. Copy this file to .env.development (gitignored).
#        cp .env.development.example .env.development
#   2. Fill in the connection string for the Neon `dev` branch
#      (project: dynasty-dna, branch: dev). Get it from the Neon console.
#
# Two variables, by design:
#
#   DATABASE_URL=<dev-branch-url>
#     Used by `npm run db:dev:push|seed|reset`. drizzle-kit reads
#     process.env.DATABASE_URL — `dotenv -e .env.development` scopes that
#     to the dev URL so prod stays untouched.
#
#   DATABASE_URL_DEV=<dev-branch-url>
#     Used by `npm run dev` and other Next-loaded contexts. .env.local
#     carries the prod DATABASE_URL (pulled from Vercel), and Next loads
#     .env.local *after* .env.development — so prod wins unless an explicit
#     DATABASE_URL_DEV is set. The resolver in src/db/index.ts prefers
#     DATABASE_URL_DEV off-Vercel, falling back to DATABASE_URL.
#
# Selection logic (see src/db/index.ts → resolveDatabaseUrl):
#   - On Vercel (any VERCEL_ENV) -> always DATABASE_URL. No redirect.
#   - Off-Vercel              -> DATABASE_URL_DEV if set, else DATABASE_URL.
#
# NEVER commit a real connection string. Real env files are gitignored;
# only *.example templates are tracked.

DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DEV=postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
