# Local development environment template — read by `dotenv -e .env.development`
# in the `db:dev:*` scripts (push, migrate, studio, reset, seed).
#
# Setup:
#   1. cp .env.development.example .env.development      (real file is gitignored)
#   2. Paste the Neon `dev` branch connection string into BOTH variables below.
#      (project: dynasty-dna, branch: dev — copy from the Neon console.)
#
# Why two variables — they live in two different files at runtime:
#
#   DATABASE_URL  (this file, .env.development)
#     `dotenv -e .env.development -- drizzle-kit ...` and `tsx scripts/reset-db.ts`
#     read process.env.DATABASE_URL. Scoping it here means the dev scripts hit
#     the dev branch even if .env.local would otherwise override it.
#
#   DATABASE_URL_DEV  (typically .env.local)
#     `npm run dev` and any code path that calls `getDb()` go through
#     resolveDatabaseUrl() in src/db/index.ts, which prefers DATABASE_URL_DEV
#     when off-Vercel. Set this in .env.local so `next dev` transparently
#     uses the dev branch without disturbing the prod DATABASE_URL that
#     `vercel env pull` writes there.
#
#   Both are duplicated in *this* template file purely as a copy-paste
#   convenience — when you fill them in here they are identical. At runtime
#   only DATABASE_URL is read from this file (by the `db:dev:*` scripts).
#
# Selection logic (see src/db/index.ts → resolveDatabaseUrl):
#   - On Vercel (any VERCEL_ENV) -> always DATABASE_URL. No redirect.
#   - Off-Vercel               -> DATABASE_URL_DEV if set, else DATABASE_URL.
#
# Safety: `npm run db:dev:reset` refuses to run unless the resolved host
# looks like a dev branch (contains "-dev." or "dev-branch", appears in
# NEON_DEV_HOST_ALLOWLIST, or --i-know-this-is-prod is passed).
#
# NEVER commit a real connection string. Real env files are gitignored;
# only *.example templates are tracked.

DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-dev.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DEV=postgresql://USER:PASSWORD@ep-XXXX-dev.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
